train.category = "Musical_Instruments"
train.modality = "multimodal"

train.iterations = 100000
train.batch_size = 64
train.learning_rate = 0.001
train.weight_decay = 0.0001
train.train_data_subsample = False

# Must match the trained RQ-VAE checkpoint
# Qwen3-VL-Embedding-2B hidden size = 1536
train.vae_input_dim = 2048
train.vae_embed_dim = 32
train.vae_hidden_dims = [768, 512, 256]
train.vae_codebook_size = 256
train.vae_n_layers = 3
train.vae_n_cat_feats = 0
train.vae_codebook_normalize = False
train.vae_sim_vq = False
train.pretrained_rqvae_path = "out/rqvae/Musical_Instruments/multimodal/checkpoint_best.pt"

# Qwen/Qwen3.5-0.8B
train.qwen_model_name = "Qwen/Qwen3.5-0.8B"
train.freeze_encoder = False
train.top_k_for_generation = 20
train.should_add_sep_token = True

train.save_dir_root = "out/decoder/"
train.save_model_every = 2000
train.eval_every = 2000
train.log_every = 100
train.top_k_eval_list = [1, 5, 10]
train.wandb_logging = False
train.amp = False
